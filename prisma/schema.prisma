generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  emailVerified  DateTime?
  password       String?
  name           String?
  avatar         String?
  image          String?
  role           Role               @default(USER)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accounts       Account[]
  activityLogs   ActivityLog[]
  notifications  Notification[]
  sessions       Session[]
  trees          Tree[]
  collaborations TreeCollaborator[]
}

model Tree {
  id            String             @id @default(cuid())
  name          String
  description   String?
  isPublic      Boolean            @default(false)
  ownerId       String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  generations   Generation[]
  invites       Invite[]
  members       Member[]
  owner         User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators TreeCollaborator[]

  @@index([ownerId])
}

model TreeCollaborator {
  id        String   @id @default(cuid())
  role      TreeRole @default(VIEWER)
  userId    String
  treeId    String
  createdAt DateTime @default(now())
  tree      Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, treeId])
  @@index([treeId])
  @@index([userId])
}

model Generation {
  id         String   @id @default(cuid())
  name       String
  orderIndex Int
  treeId     String
  createdAt  DateTime @default(now())
  tree       Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)
  members    Member[]

  @@index([treeId])
}

model Member {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  middleName    String?
  birthDate     DateTime?
  deathDate     DateTime?
  gender        Gender?
  bio           String?
  imageUrl      String?        @map("avatar")
  coverImage    String?
  phone         String?
  email         String?
  address       String?
  occupation    String?
  generationId  String
  treeId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  media         Media[]
  generation    Generation     @relation(fields: [generationId], references: [id])
  tree          Tree           @relation(fields: [treeId], references: [id], onDelete: Cascade)
  relationsFrom Relationship[] @relation("from")
  relationsTo   Relationship[] @relation("to")

  @@index([treeId])
  @@index([treeId, lastName])
}

model Relationship {
  id        String           @id @default(cuid())
  type      RelationshipType
  fromId    String
  toId      String
  createdAt DateTime         @default(now())
  from      Member           @relation("from", fields: [fromId], references: [id], onDelete: Cascade)
  to        Member           @relation("to", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  caption   String?
  eventTag  String?
  type      String   @default("image")
  memberId  String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model ActivityLog {
  id         String       @id @default(cuid())
  type       ActivityType
  entityType String
  entityId   String
  metadata   Json?
  userId     String
  createdAt  DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Invite {
  id        String   @id @default(cuid())
  email     String?
  role      TreeRole @default(VIEWER)
  token     String   @unique
  treeId    String
  invitedBy String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  tree      Tree     @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@index([treeId])
}

enum Role {
  USER
  ADMIN
}

enum TreeRole {
  VIEWER
  EDITOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RelationshipType {
  PARENT
  SPOUSE
}

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  VIEW
}
