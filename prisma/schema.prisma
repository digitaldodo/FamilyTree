// Prisma Schema — FamilyTree SaaS
// TODO: Run `npx prisma migrate dev` after configuring DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// TODO: Implement User model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  role      Role     @default(USER)
  trees     Tree[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TODO: Implement Tree model
model Tree {
  id          String   @id @default(cuid())
  name        String
  description String?
  owner       User     @relation(fields: [ownerId], references: [id])
  ownerId     String
  members     Member[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// TODO: Implement Member model
model Member {
  id            String         @id @default(cuid())
  firstName     String
  lastName      String
  birthDate     DateTime?
  deathDate     DateTime?
  gender        Gender?
  bio           String?
  avatar        String?
  tree          Tree           @relation(fields: [treeId], references: [id])
  treeId        String
  relationsFrom Relationship[] @relation("from")
  relationsTo   Relationship[] @relation("to")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// TODO: Implement Relationship model
model Relationship {
  id     String           @id @default(cuid())
  type   RelationshipType
  from   Member           @relation("from", fields: [fromId], references: [id])
  fromId String
  to     Member           @relation("to", fields: [toId], references: [id])
  toId   String

  @@unique([fromId, toId, type])
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RelationshipType {
  PARENT
  SPOUSE
  SIBLING
}
